# ============================================================
# Sports Prediction Dashboard — Environment Configuration
# ============================================================
# Copy to .env and fill in your API keys.
# The app runs fully with mock data without any keys.

# ----- Football Data (football-data.org) -----
# Free tier: 10 req/min, covers BL1, PL, PD
# Get your key at: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# ----- OpenLigaDB (1. + 2. Bundesliga) -----
# Kostenlos, kein API-Key, kein Rate-Limit. Lizenz: ODbL
# Doku: https://www.openligadb.de
OPENLIGADB_BASE_URL=https://api.openligadb.de

# ----- Süper Lig Provider (secondary football provider) -----
# Plug in your preferred API for Turkish Süper Lig
# The adapter is ready — just set URL + key
SUPERLIG_API_KEY=
SUPERLIG_API_URL=

# ----- Odds API (für Bookmaker-Quoten, z. B. Betano) -----
# The-Odds-API ist ein kostenloser Aggregator, der Quoten von vielen
# Bookmakern liefert (inkl. Betano für EU-Sportarten).  Free-Tier:
# 500 Requests/Monat — reicht bei 1× tgl. Refresh aller 5 Sportarten.
# Key registrieren: https://the-odds-api.com/
ODDS_API_KEY=
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
# Welcher Bookmaker zählt für Pick-Vorschläge.  Default: betano.
# Andere Optionen: bet365, bwin, tipico, unibet, ladbrokes, ...
ODDS_BOOKMAKER=betano
# Mindest-Bookmaker-Quote ab der ein Pick als Vorschlag erscheint.
ODDS_MIN_BOOKMAKER_ODDS=1.25
# Region(en) für The-Odds-API (kommasepariert): eu, uk, us, au.
ODDS_API_REGIONS=eu

# ----- Provider Selection -----
# football_data | mock
FOOTBALL_PROVIDER=football_data
# nhl_api | mock
HOCKEY_PROVIDER=nhl_api
# odds_api | mock
ODDS_PROVIDER=mock

# ----- Fallback -----
# If true, falls back to mock data when provider is unavailable
USE_MOCK_FALLBACK=true

# ----- App Config -----
DEBUG=true
DATABASE_URL=sqlite:///./data/predictions.db
MODEL_DIR=./data/models

# ----- Active Leagues -----
# Comma-separated list
ACTIVE_FOOTBALL_LEAGUES=["BL1","BL2","PL","PD","SSL"]
ACTIVE_HOCKEY_LEAGUES=["NHL"]
ACTIVE_BASKETBALL_LEAGUES=["NBA"]
ACTIVE_BASEBALL_LEAGUES=["MLB"]

# ----- Top3 Ranking Weights (must sum to 1.0) -----
TOP3_W_CONFIDENCE=0.4
TOP3_W_MODEL_AGREEMENT=0.3
TOP3_W_STABILITY=0.2
TOP3_W_EDGE=0.1
